# Barkley DogGraph — environment variables
# Copy to .env (not committed) OR `export` them in your shell.
# The Python modules call os.environ directly; no .env loader is bundled.

# --- Neo4j AuraDB connection (required) ----------------------------------
NEO4J_URI=neo4j+s://<your-instance-id>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-aura-password>

# --- Anthropic (optional, enables the LLM/GraphRAG layer in graph_query_llm.py)
# Without this key, the demo falls back to the deterministic intent router
# in graph_query.py. The LLM layer is read-only validated either way.
ANTHROPIC_API_KEY=<your-anthropic-key>
# Optional override; default is claude-haiku-4-5-20251001
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
