# The variables ask.py reads directly from the environment. Export them in your
# shell (see README), or load this file with your own dotenv tool — the demo code
# does not auto-load .env. Get the values from your Neo4j AuraDB instance.
# Do not commit real credentials.
NEO4J_URI="neo4j+s://<your-aura-id>.databases.neo4j.io"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="<your-aura-password>"
