# Barkley DogGraph — deploy secrets.
# On the server: copy to `.env` next to docker-compose.yml (it is git-ignored).
# Never commit real values.

# A long random string you choose (this becomes the Neo4j password).
NEO4J_PASSWORD=change-me-to-a-long-random-string

# Your Anthropic key — enables the LLM / GraphRAG layer.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (default is fine).
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
